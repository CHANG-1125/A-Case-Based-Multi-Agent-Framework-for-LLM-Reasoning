# --- UniAPI 中转（OpenAI 兼容，控制台：https://uniapi.ai/dashboard/key ）---
# 文档：https://docs.uniapi.ai/docs/use/api/openai_compatible
USE_UNIAPI=1
# 任选其一：与 OpenAI SDK 一致用 OPENAI_API_KEY，或单独写 UNIAPI_API_KEY
OPENAI_API_KEY=your-uniapi-key
# UNIAPI_API_KEY=your-uniapi-key
# 全球节点（默认）：https://api.uniapi.io/v1
# 大陆优化：https://hk.uniapi.io/v1
# UNIAPI_BASE_URL=https://api.uniapi.io/v1

OPENAI_MODEL=gpt-4o-mini
# 若中转仍报 JSON 相关 400，可尝试把 system+user 合并为单条 user（少数网关对 system 不兼容）
# LLM_SINGLE_USER_MESSAGE=1
# 读响应超时（秒）：长推理/中转排队时易触发 ReadTimeout，默认 600
# OPENAI_READ_TIMEOUT=600
# 兼容旧变量：仅当未设 OPENAI_READ_TIMEOUT 时生效
# OPENAI_TIMEOUT=600
# OPENAI_CONNECT_TIMEOUT=60
# LLM_MAX_RETRIES=3

# 全量 GSM8K 测试集：python run_experiments.py --full_test ...
# 强约束（Judge 必须输出可机器校验的 KEY_CALC）：STRONG_CONSTRAINTS=1 或 --strong_constraints
# STRONG_CONSTRAINTS=1
# KEY_CALC 行数（默认更宽松：至少 1 行，至多 10 行；超出只校验前 N 行）
# KEY_CALC_MIN_LINES=1
# KEY_CALC_MAX_LINES=10

# Hugging Face（数据集/embedding）：网络不稳或 SSL 报错时可设
# HF_HUB_DISABLE_EXPERIMENTAL_HTTPX=1
# 仅使用本地已缓存的 sentence-transformers 模型（需曾成功下载过）
# EMBEDDING_LOCAL_FILES_ONLY=1
# 可选镜像（自行评估可用性）：HF_ENDPOINT=https://hf-mirror.com
# 若出现 SSL UNEXPECTED_EOF 且栈里有 httpx http_proxy：多为环境变量代理干扰，保持默认即可（已 trust_env=False）
# 只有必须经公司代理访问外网时再设：HTTPX_TRUST_ENV=1

# --- 直连 OpenAI / 其他兼容服务时：注释掉 USE_UNIAPI，并自行设置 BASE_URL ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional overrides
# GENERATOR_TEMPERATURE=0.3
# CRITIC_TEMPERATURE=0
# JUDGE_TEMPERATURE=0
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# TOP_K=3
